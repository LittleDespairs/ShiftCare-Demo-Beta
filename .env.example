# ShiftCare 0.20.3 beta environment template.
# Copy to .env for local development. Never commit real secrets.

APP_ENV=development
APP_VERSION_LINE=0.20.3_beta

# Local development server
APP_HOST=127.0.0.1
APP_PORT=8000
SCHEDULE_APP_DEFAULT_API_BASE_URL=https://portal.shiftcare.co.il
PUBLIC_APP_BASE_URL=https://portal.shiftcare.co.il

# Database
# sqlite remains the desktop/local default.
# Cloud Run beta uses postgres/postgresql through Cloud SQL.
DATABASE_ENGINE=sqlite
SCHEDULE_APP_DATABASE_PATH=

# PostgreSQL / Cloud SQL settings
DATABASE_NAME=schedule_beta
DATABASE_USER=schedule_app
DATABASE_PASSWORD=
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_SSL_MODE=require

# Google Cloud SQL
GOOGLE_CLOUD_PROJECT=schedule-app-beta
GOOGLE_CLOUD_REGION=me-west1
CLOUD_SQL_CONNECTION_NAME=schedule-app-beta:me-west1:schedule-beta-db

# Auth
AUTH_TOKEN_SECRET=
AUTH_ACCESS_TOKEN_MINUTES=60
AUTH_REFRESH_TOKEN_DAYS=30

# Email delivery for invitations, password reset, and email verification.
# Leave EMAIL_ENABLED=0 in local development to keep returning debug tokens in API responses.
EMAIL_ENABLED=0
EMAIL_FROM="ShiftCare <no-reply@shiftcare.co.il>"
EMAIL_REPLY_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=1
SMTP_USE_SSL=0

# Read-only beta/developer support dashboard at /support.
# Keep disabled for customer installs unless support access is required.
# Desktop builds can also enable it with:
# %LOCALAPPDATA%\Schedule App\developer_mode.flag
SCHEDULE_APP_DEVELOPER_MODE=0

# Local license development and support.
# Keep the real value outside git. It is used by tools/issue_license.py
# and by the desktop runtime to verify temporary HMAC-signed beta licenses.
SCHEDULE_APP_LICENSE_SIGNING_SECRET=

# Local-only license bypass for development and QA.
# This is ignored in staging/production/cloud runtimes.
SCHEDULE_APP_LICENSE_BYPASS=0
